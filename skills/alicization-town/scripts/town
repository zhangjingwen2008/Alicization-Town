    }
    function formatChat(messages, selfText) {
      let info = "";
      if (selfText) info += `\u4F60\u8BF4: ${selfText}

`;
      if (!messages || messages.length === 0) {
        info += "\u{1F4AC} \u5C0F\u9547\u8FD8\u5F88\u5B89\u9759\uFF0C\u6CA1\u6709\u4EBA\u8BF4\u8BDD\u3002";
        return info;
      }
      info += "\u{1F4AC} \u3010\u5C0F\u9547\u804A\u5929\u9891\u9053\u3011\n";
      for (const msg of messages) {
        const t = new Date(msg.time);
        const ts = `${String(t.getHours()).padStart(2, "0")}:${String(t.getMinutes()).padStart(2, "0")}`;
        info += `[${ts}] ${msg.name}: ${msg.message}
`;
      }
      return info.trimEnd();
    }
    function formatPerceptions(perceptions) {
      if (!perceptions || perceptions.length === 0) return "";
      const typeLabels = {
        chat: "\u{1F4AC}",
        interact: "\u{1F3AD}",
        move: "\u{1F6B6}",
        join: "\u{1F44B}",
        leave: "\u{1F44B}"
      };
      let info = "\n\n\u{1F4E1} \u3010\u73AF\u5883\u611F\u77E5\u3011 \u4F60\u6CE8\u610F\u5230\u4E86\u4EE5\u4E0B\u4E8B\u4EF6\uFF1A\n";
      for (const event of perceptions) {
        const icon = typeLabels[event.type] || "\u2022";
        const attentionBar = event.attention >= 0.7 ? "\u26A1" : event.attention >= 0.4 ? "\u25CF" : "\u25CB";
        if (event.type === "chat") {
          info += `${attentionBar} ${icon} ${event.from} \u8BF4: "${event.text}" (\u8DDD\u79BB ${event.distance} \u6B65)
`;
        } else if (event.type === "interact") {
          info += `${attentionBar} ${icon} ${event.from} \u5728${event.zone}\u8FDB\u884C\u4E86: ${event.action} (\u8DDD\u79BB ${event.distance} \u6B65)
`;
        } else if (event.type === "move") {
          info += `${attentionBar} ${icon} ${event.from} \u79FB\u52A8\u5230\u4E86${event.zone} (\u8DDD\u79BB ${event.distance} \u6B65)
`;
        } else if (event.type === "join") {
          info += `${attentionBar} ${icon} ${event.from} \u52A0\u5165\u4E86\u5C0F\u9547
`;
        } else if (event.type === "leave") {
          info += `${attentionBar} ${icon} ${event.from} \u79BB\u5F00\u4E86\u5C0F\u9547
`;
        }
      }
      return info.trimEnd();
    }
    function parseFlags(args2) {
      const result = { _: [] };
      for (let index = 0; index < args2.length; index += 1) {
        const current = args2[index];
        if (!current.startsWith("--")) {
          result._.push(current);
          continue;
        }
        const key = current.slice(2);
        const next = args2[index + 1];
        if (next && !next.startsWith("--")) {
          result[key] = next;
          index += 1;
        } else {
          result[key] = true;
        }
      }
      return result;
    }
