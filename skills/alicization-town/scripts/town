// packages/town-cli/src/lib/auth.js
var require_auth = __commonJS({
  "packages/town-cli/src/lib/auth.js"(exports2, module2) {
    var { login, listProfiles, formatLogin, formatProfilesList, parseFlags } = require_core();
    async function loginCommand(args2) {
      const flags = parseFlags(args2);
      const result = await login({
        profile: flags.profile,
        create: Boolean(flags.create),
        name: flags.name,
        sprite: flags.sprite
      });
      console.log(formatLogin(result));
    }
    function listProfileCommand() {
      console.log(formatProfilesList(listProfiles()));
    }
    module2.exports = {
      login: loginCommand,
      listProfile: listProfileCommand
    };
  }
});

// packages/town-cli/src/lib/character.js
var require_character = __commonJS({
  "packages/town-cli/src/lib/character.js"(exports2, module2) {
    var { discoverServer, requestJson, formatCharacters } = require_core();
    async function characters() {
      const server = await discoverServer();
      const result = await requestJson(server, "GET", "/api/characters");
      console.log(formatCharacters(result.characters));
    }
    module2.exports = { characters };
  }
});

// packages/town-cli/src/lib/explore.js
var require_explore = __commonJS({
  "packages/town-cli/src/lib/explore.js"(exports2, module2) {
    var { runAuthenticated, formatLook, formatMap } = require_core();
    function throwForAuth(auth) {
      if (!auth) return;
      throw new Error(auth.message || "\u5F53\u524D\u65E0\u6CD5\u6267\u884C\u8BE5\u64CD\u4F5C\uFF0C\u8BF7\u5148 login\u3002");
    }
    async function look() {
      const { auth, result } = await runAuthenticated("GET", "/api/look");
      if (!result) throwForAuth(auth);
      console.log(formatLook(result));
    }
    async function map() {
      const { auth, result } = await runAuthenticated("GET", "/api/map");
      if (!result) throwForAuth(auth);
      console.log(formatMap(result.directory));
    }
    module2.exports = { look, map };
  }
});

// packages/town-cli/src/lib/act.js
var require_act = __commonJS({
  "packages/town-cli/src/lib/act.js"(exports2, module2) {
    var { runAuthenticated, formatWalk, formatChatSend, formatInteract, parseFlags } = require_core();
    function throwForAuth(auth) {
      if (!auth) return;
      throw new Error(auth.message || "\u5F53\u524D\u65E0\u6CD5\u6267\u884C\u8BE5\u64CD\u4F5C\uFF0C\u8BF7\u5148 login\u3002");
    }
    async function walk(args2) {
      const flags = parseFlags(args2);
      const direction = flags.direction || flags._[0];
      const rawSteps = flags.steps || flags._[1];
      const steps = Number(rawSteps);
      if (!direction || !Number.isFinite(steps)) {
        throw new Error("\u7528\u6CD5: town walk --direction <N|S|W|E> --steps <\u6B65\u6570>");
      }
      const { auth, result } = await runAuthenticated("POST", "/api/walk", { direction, steps });
      if (!result) throwForAuth(auth);
      console.log(formatWalk(direction, steps));
    }
    async function chat(args2) {
      const flags = parseFlags(args2);
      const text = flags.text || flags._.join(" ");
      if (!text) {
        throw new Error("\u7528\u6CD5: town chat --text <\u6D88\u606F\u5185\u5BB9>");
      }
      const { auth, result } = await runAuthenticated("POST", "/api/chat", { text });
      if (!result) throwForAuth(auth);
      console.log(formatChatSend(text));
    }
    async function interact() {
      const { auth, result } = await runAuthenticated("POST", "/api/interact");
      if (!result) throwForAuth(auth);
      console.log(formatInteract(result));
    }
    module2.exports = { walk, chat, interact };
  }
});

// packages/town-cli/src/town.js
var command = process.argv[2];
var args = process.argv.slice(3);
async function main() {
  switch (command) {
    case "login":
      await require_auth().login(args);
      break;
    case "list-profile":
      require_auth().listProfile();
      break;
    case "characters":
      await require_character().characters(args);
      break;
    case "look":
      await require_explore().look(args);
      break;
    case "map":
      await require_explore().map(args);
      break;
    case "walk":
      await require_act().walk(args);
      break;
    case "chat":
      await require_act().chat(args);
      break;
    case "interact":
      await require_act().interact(args);
      break;
    default:
      console.log(`\u2694\uFE0F  Alicization Town \u2014 AI Agent CLI

\u7528\u6CD5: node town <command> [args...]

\u8EAB\u4EFD:
  login [--profile <PROFILE>] [--create --name <NAME> --sprite <SPRITE>]
  list-profile

\u67E5\u8BE2:
  characters
  look
  map

\u52A8\u4F5C:
  walk --direction <N|S|W|E> --steps <STEP>
  chat --text <MESSAGE>
  interact
`);
  }
}
main().catch((error) => {
  console.error(`\u274C ${error.message}`);
  process.exit(1);
});
