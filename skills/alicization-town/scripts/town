\u73AF\u5883\u63CF\u8FF0: ${player.zoneDesc}

`;
      }
      if (nearby.length === 0) {
        info += "\u56DB\u5468\u7A7A\u65E0\u4E00\u4EBA\u3002";
        return info;
      }
      info += "\u{1F465} \u3010\u9644\u8FD1\u7684\u4EBA\u3011\n";
      nearby.forEach((person) => {
        info += `- ${person.name} \u8DDD\u79BB\u4F60 ${person.distance} \u6B65 (\u4F4D\u4E8E ${person.zone})`;
        if (person.message) info += `\uFF0C\u4ED6\u6B63\u5728\u8BF4: "${person.message}"`;
        info += "\n";
      });
      return info.trimEnd();
    }
    function formatWalk(direction, steps) {
      return `\u4F60\u8BD5\u56FE\u5411 ${direction} \u8D70 ${steps} \u6B65\u3002\u8BF7\u7528 look \u786E\u8BA4\u662F\u5426\u5230\u8FBE\uFF0C\u6216\u662F\u5426\u649E\u5899\u3002`;
    }
    function formatChatSend(text) {
      return `\u4F60\u8BF4: ${text}`;
    }
    function formatInteract(result) {
      return `\u{1F3AD} \u3010\u4E92\u52A8\u3011
\u{1F4CD} \u5730\u70B9: ${result.zone}
\u{1F3AC} \u884C\u52A8: ${result.action}

\u{1F4D6} ${result.result}`;
    }
    function parseFlags(args2) {
      const result = { _: [] };
      for (let index = 0; index < args2.length; index += 1) {
        const current = args2[index];
        if (!current.startsWith("--")) {
          result._.push(current);
          continue;
        }
        const key = current.slice(2);
        const next = args2[index + 1];
        if (next && !next.startsWith("--")) {
          result[key] = next;
          index += 1;
        } else {
          result[key] = true;
        }
      }
      return result;
    }
    module2.exports = {
      stringifyResult,
      formatProfilesList,
      formatLogin,
      formatCharacters,
      formatMap,
      formatLook,
      formatWalk,
      formatChatSend,
      formatInteract,
      parseFlags
    };
  }
});

