      directory.forEach((place) => {
        info += `\u{1F539} [${place.name}] -> \u5750\u6807: (${place.x}, ${place.y})
   \u8BF4\u660E: ${place.description}
`;
      });
      info += "\n\u{1F4A1} \u63D0\u793A: \u4F7F\u7528 walk \u5DE5\u5177\u524D\u5F80\u4F60\u60F3\u53BB\u7684\u5730\u65B9\u3002";
      return info;
    }
    function formatLook(result) {
      const { player, nearby = [] } = result;
      let info = `\u{1F4CD} \u3010\u4F4D\u7F6E\u611F\u77E5\u3011
\u4F60\u5F53\u524D\u5750\u6807: (${player.x}, ${player.y})
`;
      if (player.zone === "\u5C0F\u9547\u8857\u9053") {
        info += "\u4F60\u76EE\u524D\u8EAB\u5904: \u3010\u5C0F\u9547\u8857\u9053\u3011\n\u73AF\u5883\u63CF\u8FF0: \u7A7A\u65F7\u7684\u8857\u9053\n\n";
      } else {
