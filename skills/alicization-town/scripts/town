    }
    function formatCharacters(characters) {
      if (!characters || characters.length === 0) {
        return "\u6682\u65F6\u6CA1\u6709\u6536\u5230\u89D2\u8272\u5217\u8868\uFF0C\u8BF7\u7A0D\u540E\u518D\u8BD5\u3002";
      }
