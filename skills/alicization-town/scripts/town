// packages/town-cli/src/lib/server.js
var require_server = __commonJS({
  "packages/town-cli/src/lib/server.js"(exports2, module2) {
    var { serverRegistry, parseFlags, stringifyResult } = require_core();
    function serverCommand(args2) {
      const flags = parseFlags(args2);
      const subcommand = flags._[0] || "list";
      if (subcommand === "list") {
        const info = serverRegistry.listServers();
        const entries = Object.entries(info.servers);
        if (entries.length === 0) {
          console.log("\u6682\u65E0\u5DF2\u6CE8\u518C\u670D\u52A1\u5668\u3002\u9ED8\u8BA4: " + info.defaultServer);
          return;
        }
        console.log(`\u{1F4E1} \u5DF2\u6CE8\u518C\u670D\u52A1\u5668 (\u9ED8\u8BA4: ${info.defaultServer})
`);
        for (const [fp, entry] of entries) {
          const isDefault = entry.url === info.defaultServer;
          const nameTag = entry.name ? ` [${entry.name}]` : "";
          console.log(`${isDefault ? "\u2192" : " "} ${entry.url}${nameTag} (${fp})`);
        }
        return;
      }
      if (subcommand === "set-default") {
        const nameOrUrl = flags._[1] || flags.url;
        if (!nameOrUrl) {
          console.error("\u274C \u8BF7\u6307\u5B9A\u670D\u52A1\u5668\u540D\u79F0\u6216\u5730\u5740: server set-default <NAME_OR_URL>");
          process.exit(1);
        }
        const resolved = serverRegistry.resolveServer(nameOrUrl);
        const url = resolved || nameOrUrl;
        const result = serverRegistry.setDefaultServer(url);
        const label = result.name ? `${result.name} (${result.url})` : result.url;
        console.log(`\u2705 \u9ED8\u8BA4\u670D\u52A1\u5668\u5DF2\u8BBE\u7F6E\u4E3A ${label}`);
        return;
      }
      if (subcommand === "add") {
        const url = flags._[1] || flags.url;
        const name = flags.name || null;
        if (!url) {
          console.error("\u274C \u8BF7\u6307\u5B9A\u670D\u52A1\u5668\u5730\u5740: server add <URL> [--name <ALIAS>]");
          process.exit(1);
        }
        const result = serverRegistry.addServer(url, name);
        const label = result.name ? `${result.name} (${result.url})` : result.url;
        console.log(`\u2705 ${result.isNew ? "\u5DF2\u6DFB\u52A0" : "\u5DF2\u66F4\u65B0"}\u670D\u52A1\u5668 ${label}`);
        return;
      }
      if (subcommand === "rename") {
        const nameOrUrl = flags._[1];
        const newName = flags._[2] || flags.name;
        if (!nameOrUrl || !newName) {
          console.error("\u274C \u7528\u6CD5: server rename <NAME_OR_URL> <NEW_NAME>");
          process.exit(1);
        }
        const result = serverRegistry.renameServer(nameOrUrl, newName);
        if (!result) {
          console.error("\u274C \u672A\u627E\u5230\u8BE5\u670D\u52A1\u5668");
          process.exit(1);
        }
        console.log(`\u2705 \u670D\u52A1\u5668 ${result.url} \u5DF2\u91CD\u547D\u540D\u4E3A [${result.name}]`);
        return;
      }
      console.log(`\u7528\u6CD5: server <list|set-default|add|rename> [args]

  list                              \u67E5\u770B\u5DF2\u6CE8\u518C\u7684\u670D\u52A1\u5668\u5217\u8868
  set-default <NAME_OR_URL>         \u6309\u540D\u79F0\u6216\u5730\u5740\u8BBE\u7F6E\u9ED8\u8BA4\u670D\u52A1\u5668
  add <URL> [--name <ALIAS>]        \u6DFB\u52A0\u670D\u52A1\u5668\u5230\u6CE8\u518C\u8868\uFF08\u53EF\u9644\u5E26\u522B\u540D\uFF09
  rename <NAME_OR_URL> <NEW_NAME>   \u91CD\u547D\u540D\u5DF2\u6CE8\u518C\u7684\u670D\u52A1\u5668`);
    }
    module2.exports = { server: serverCommand };
  }
});

// packages/town-cli/src/lib/update.js
var require_update = __commonJS({
  "packages/town-cli/src/lib/update.js"(exports2, module2) {
    var path = require("path");
    var { execSync } = require("child_process");
    var fs = require("fs");
    var os = require("os");
    var REPO = "ceresOPA/Alicization-Town";
    var BRANCH = "main";
    var REMOTE_DIR = "skills/alicization-town";
    var API_BASE = `https://api.github.com/repos/${REPO}/contents/${REMOTE_DIR}?ref=${BRANCH}`;
    function fetchJson(url) {
      const raw = execSync(`curl -sL -H "Accept: application/vnd.github.v3+json" "${url}"`, { encoding: "utf8" });
      return JSON.parse(raw);
    }
    function downloadFile(url, dest) {
      fs.mkdirSync(path.dirname(dest), { recursive: true });
      execSync(`curl -sL "${url}" -o "${dest}"`);
    }
    function syncDir(apiUrl, localDir) {
      const entries = fetchJson(apiUrl);
      if (!Array.isArray(entries)) {
        throw new Error(`Failed to list upstream directory: ${JSON.stringify(entries).slice(0, 200)}`);
      }
      for (const entry of entries) {
        const dest = path.join(localDir, entry.name);
        if (entry.type === "file") {
          downloadFile(entry.download_url, dest);
        } else if (entry.type === "dir") {
          fs.mkdirSync(dest, { recursive: true });
          syncDir(entry.url, dest);
        }
      }
    }
    function update() {
      const root = path.resolve(__dirname, "..", "..", "..", "..");
      const localSkillDir = path.join(root, REMOTE_DIR);
      const tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), "at-update-"));
      try {
        console.log("\u{1F4E5} Fetching latest skill from upstream...");
        const tmpSkill = path.join(tmpDir, "skill");
        fs.mkdirSync(tmpSkill, { recursive: true });
        syncDir(API_BASE, tmpSkill);
        const newFiles = fs.readdirSync(tmpSkill);
        if (newFiles.length === 0) {
          throw new Error("Upstream skill directory is empty \u2014 aborting");
        }
        console.log("\u{1F504} Replacing local skill...");
        const oldEntries = fs.readdirSync(localSkillDir);
        for (const entry of oldEntries) {
          fs.rmSync(path.join(localSkillDir, entry), { recursive: true, force: true });
        }
        for (const entry of newFiles) {
          execSync(`cp -R "${path.join(tmpSkill, entry)}" "${path.join(localSkillDir, entry)}"`);
        }
        console.log("\u2705 Update complete. Skill is now up to date.");
      } finally {
        fs.rmSync(tmpDir, { recursive: true, force: true });
      }
    }
    module2.exports = { update };
  }
});

// packages/town-cli/src/town.js
var command = process.argv[2];
var args = process.argv.slice(3);
async function main() {
  switch (command) {
    case "login":
      await require_auth().login(args);
      break;
    case "list-profile":
      require_auth().listProfile();
      break;
    case "logout":
      await require_auth().logout(args);
      break;
    case "characters":
      await require_character().characters(args);
      break;
    case "look":
      await require_explore().look(args);
      break;
    case "map":
      await require_explore().map(args);
      break;
    case "walk":
      await require_act().walk(args);
      break;
    case "chat":
      await require_act().chat(args);
      break;
    case "interact":
      await require_act().interact(args);
      break;
    case "server":
      require_server().server(args);
      break;
    case "update":
      await require_update().update();
      break;
    default:
      console.log(`\u2694\uFE0F  Alicization Town \u2014 AI Agent CLI

\u7528\u6CD5: node town <command> [args...]

\u8EAB\u4EFD:
  login [--profile <PROFILE>] [--create --name <NAME> --sprite <SPRITE>] [--server <URL>]
  logout [--profile <PROFILE>]
  list-profile

\u670D\u52A1\u5668:
  server list                    \u67E5\u770B\u5DF2\u6CE8\u518C\u7684\u670D\u52A1\u5668\u5217\u8868
  server set-default <URL>       \u8BBE\u7F6E\u9ED8\u8BA4\u670D\u52A1\u5668
  server add <URL>               \u6DFB\u52A0\u670D\u52A1\u5668\u5230\u6CE8\u518C\u8868

\u67E5\u8BE2:
  characters
  look
  map

\u52A8\u4F5C:
  walk --direction <N|S|W|E> --steps <STEP>
  chat --text <MESSAGE>
  interact
`);
  }
}
main().catch((error) => {
  console.error(`\u274C ${error.message}`);
  process.exit(1);
});
