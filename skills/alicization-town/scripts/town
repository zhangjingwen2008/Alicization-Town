    }
    function getProfileOrThrow(profileName, server) {
      const serverFp = resolveServerFingerprint(server);
      const resolvedProfile = resolveProfileName(profileName, server);
      if (!resolvedProfile) {
        throw new Error("\u672C\u5730\u8FD8\u6CA1\u6709 profile\uFF0C\u8BF7\u4F7F\u7528 login \u7684\u521B\u5EFA\u6A21\u5F0F\u521B\u5EFA\u89D2\u8272\u3002");
